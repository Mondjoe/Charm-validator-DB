# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local and fill in
# NEVER commit actual .env files
# ============================================

# Ethereum / EVM Chains
REACT_APP_ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
REACT_APP_ETH_CHAIN_ID=1

# Solana
REACT_APP_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
REACT_APP_SOLANA_NETWORK=mainnet-beta

# TRON
REACT_APP_TRON_RPC_URL=https://api.tronstack.com

# TON
REACT_APP_TON_API_KEY=YOUR_TON_API_KEY

# WalletConnect
REACT_APP_WALLET_CONNECT_PROJECT_ID=YOUR_WC_PROJECT_ID

# Contract Addresses
REACT_APP_VALIDATOR_CONTRACT=0x...
REACT_APP_MUSDT_VAULT_CONTRACT=0x...
REACT_APP_DAO_CONTRACT=0x...

# API Endpoints
REACT_APP_API_URL=https://api.charm-validator.com
REACT_APP_IPFS_GATEWAY=https://gateway.pinata.cloud

# Feature Flags
REACT_APP_ENABLE_TESTNET=false
REACT_APP_DEBUG_MODE=false
